<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F0EC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <Space android:layout_width="0dp" android:layout_height="32dp"/>

        <!-- Success emoji -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✅"
            android:textSize="56sp"
            android:layout_gravity="center_horizontal"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Order Placed!"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#6B3A2A"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your coffee is on the way ☕"
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="28dp"/>

        <!-- Order Details Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="20dp">

            <!-- Row helper: each row is a horizontal LinearLayout -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Name" android:textColor="#888888" android:textSize="14sp"/>
                <TextView android:id="@+id/tvResultName"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="#1A0A00" android:textStyle="bold" android:textSize="14sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Phone" android:textColor="#888888" android:textSize="14sp"/>
                <TextView android:id="@+id/tvResultPhone"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="#1A0A00" android:textStyle="bold" android:textSize="14sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Order" android:textColor="#888888" android:textSize="14sp"/>
                <TextView android:id="@+id/tvResultService"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="#6B3A2A" android:textStyle="bold" android:textSize="14sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Quantity" android:textColor="#888888" android:textSize="14sp"/>
                <TextView android:id="@+id/tvResultQty"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="#1A0A00" android:textStyle="bold" android:textSize="14sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Address" android:textColor="#888888" android:textSize="14sp"/>
                <TextView android:id="@+id/tvResultAddress"
                    android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textColor="#1A0A00" android:textStyle="bold"
                    android:textSize="14sp" android:gravity="end"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Payment" android:textColor="#888888" android:textSize="14sp"/>
                <TextView android:id="@+id/tvResultPayment"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="#1A0A00" android:textStyle="bold" android:textSize="14sp"/>
            </LinearLayout>

        </LinearLayout>

        <Button
            android:id="@+id/btnBackHome"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_button_primary"
            android:text="Back to Home"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="15sp"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnGoHistory"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_outline"
            android:text="View All Orders"
            android:textColor="#6B3A2A"
            android:textSize="15sp"
            android:stateListAnimator="@null"/>

    </LinearLayout>
</ScrollView>