<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F0EC"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp">

        <Space android:layout_width="0dp" android:layout_height="32dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#6B3A2A"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fill in your details below"
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="28dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Full Name" android:textSize="13sp"
            android:textColor="#6B3A2A" android:textStyle="bold"/>
        <EditText android:id="@+id/etName"
            android:layout_width="match_parent" android:layout_height="50dp"
            android:layout_marginTop="6dp" android:background="@drawable/bg_input"
            android:paddingStart="14dp" android:paddingEnd="14dp"
            android:hint="Enter your name" android:inputType="textPersonName"
            android:textSize="15sp" android:textColor="#1A0A00"
            android:textColorHint="#BBBBBB"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Phone Number" android:textSize="13sp"
            android:textColor="#6B3A2A" android:textStyle="bold"
            android:layout_marginTop="18dp"/>
        <EditText android:id="@+id/etPhone"
            android:layout_width="match_parent" android:layout_height="50dp"
            android:layout_marginTop="6dp" android:background="@drawable/bg_input"
            android:paddingStart="14dp" android:paddingEnd="14dp"
            android:hint="10-digit number" android:inputType="phone"
            android:textSize="15sp" android:textColor="#1A0A00"
            android:textColorHint="#BBBBBB"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Username" android:textSize="13sp"
            android:textColor="#6B3A2A" android:textStyle="bold"
            android:layout_marginTop="18dp"/>
        <EditText android:id="@+id/etUsername"
            android:layout_width="match_parent" android:layout_height="50dp"
            android:layout_marginTop="6dp" android:background="@drawable/bg_input"
            android:paddingStart="14dp" android:paddingEnd="14dp"
            android:hint="Choose a username" android:inputType="text"
            android:textSize="15sp" android:textColor="#1A0A00"
            android:textColorHint="#BBBBBB"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Password" android:textSize="13sp"
            android:textColor="#6B3A2A" android:textStyle="bold"
            android:layout_marginTop="18dp"/>
        <EditText android:id="@+id/etPassword"
            android:layout_width="match_parent" android:layout_height="50dp"
            android:layout_marginTop="6dp" android:background="@drawable/bg_input"
            android:paddingStart="14dp" android:paddingEnd="14dp"
            android:hint="Min 4 characters" android:inputType="textPassword"
            android:textSize="15sp" android:textColor="#1A0A00"
            android:textColorHint="#BBBBBB"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Confirm Password" android:textSize="13sp"
            android:textColor="#6B3A2A" android:textStyle="bold"
            android:layout_marginTop="18dp"/>
        <EditText android:id="@+id/etConfirm"
            android:layout_width="match_parent" android:layout_height="50dp"
            android:layout_marginTop="6dp" android:background="@drawable/bg_input"
            android:paddingStart="14dp" android:paddingEnd="14dp"
            android:hint="Re-enter password" android:inputType="textPassword"
            android:textSize="15sp" android:textColor="#1A0A00"
            android:textColorHint="#BBBBBB"/>

        <Button android:id="@+id/btnRegister"
            android:layout_width="match_parent" android:layout_height="50dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_button_primary"
            android:text="Register"
            android:textColor="#FFFFFF" android:textSize="15sp"
            android:textStyle="bold" android:stateListAnimator="@null"/>

        <Space android:layout_width="0dp" android:layout_height="24dp"/>

    </LinearLayout>
</ScrollView>