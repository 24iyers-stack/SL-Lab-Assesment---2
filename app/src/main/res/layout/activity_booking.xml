<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F0EC"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Place Order"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#6B3A2A"
            android:layout_marginTop="12dp"/>

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hello, User!"
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp"/>

        <!-- Coffee selection -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Select Coffee" android:textSize="13sp"
            android:textColor="#6B3A2A" android:textStyle="bold"/>

        <Spinner
            android:id="@+id/spinnerService"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_input"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:entries="@array/services"/>

        <!-- Customization -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Customize Your Coffee"
            android:textSize="13sp"
            android:textColor="#6B3A2A"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <!-- Size -->
        <Spinner
            android:id="@+id/spinnerSize"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_input"
            android:entries="@array/coffee_size"/>

        <!-- Add-ons -->
        <CheckBox
            android:id="@+id/cbExtraShot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Extra Espresso Shot (+₹30)"/>

        <CheckBox
            android:id="@+id/cbWhippedCream"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Whipped Cream (+₹20)"/>

        <CheckBox
            android:id="@+id/cbCold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Make it Cold (+₹10)"/>

        <!-- Quantity -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Quantity" android:textSize="13sp"
            android:textColor="#6B3A2A" android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <EditText
            android:id="@+id/etQuantity"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_input"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:hint="e.g. 2"
            android:inputType="number"
            android:textSize="15sp"
            android:textColor="#1A0A00"
            android:textColorHint="#BBBBBB"/>

        <!-- Delivery Address -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Delivery Address" android:textSize="13sp"
            android:textColor="#6B3A2A" android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <EditText
            android:id="@+id/etAddress"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_input"
            android:padding="14dp"
            android:hint="House no, Street, Area, City"
            android:inputType="textMultiLine"
            android:gravity="top"
            android:textSize="15sp"
            android:textColor="#1A0A00"
            android:textColorHint="#BBBBBB"/>

        <!-- Payment Method -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Payment Method" android:textSize="13sp"
            android:textColor="#6B3A2A" android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <Spinner
            android:id="@+id/spinnerPayment"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_input"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:entries="@array/payment_methods"/>

        <!-- Special Instructions -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Special Instructions (Optional)" android:textSize="13sp"
            android:textColor="#6B3A2A" android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <EditText
            android:id="@+id/etNote"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_input"
            android:padding="14dp"
            android:hint="e.g. Extra sugar, no ice..."
            android:inputType="textMultiLine"
            android:gravity="top"
            android:textSize="15sp"
            android:textColor="#1A0A00"
            android:textColorHint="#BBBBBB"/>

        <!-- Validation message -->
        <TextView
            android:id="@+id/tvValidation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Please fill all required fields"
            android:textColor="#E74C3C"
            android:textSize="12sp"
            android:visibility="gone"
            android:layout_marginTop="10dp"/>

        <TextView
            android:id="@+id/tvTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Total: ₹0"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#6B3A2A"
            android:layout_marginTop="16dp"/>

        <!-- Place Order button — disabled by default -->
        <Button
            android:id="@+id/btnBook"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_button_primary"
            android:text="Place Order"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:enabled="false"
            android:alpha="0.5"
            android:stateListAnimator="@null"/>

        <Space android:layout_width="0dp" android:layout_height="20dp"/>

    </LinearLayout>
</ScrollView>