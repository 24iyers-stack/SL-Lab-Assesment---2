<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F0EC"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="My Profile" android:textSize="24sp" android:textStyle="bold"
            android:textColor="#6B3A2A" android:layout_marginTop="12dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Update your information"
            android:textSize="14sp" android:textColor="#888888"
            android:layout_marginTop="4dp" android:layout_marginBottom="28dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Name" android:textSize="13sp"
            android:textColor="#6B3A2A" android:textStyle="bold"/>
        <EditText android:id="@+id/etName"
            android:layout_width="match_parent" android:layout_height="50dp"
            android:layout_marginTop="6dp" android:background="@drawable/bg_input"
            android:paddingStart="14dp" android:paddingEnd="14dp"
            android:hint="Your name" android:inputType="textPersonName"
            android:textSize="15sp" android:textColor="#1A0A00"
            android:textColorHint="#BBBBBB"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Phone" android:textSize="13sp"
            android:textColor="#6B3A2A" android:textStyle="bold"
            android:layout_marginTop="18dp"/>
        <EditText android:id="@+id/etPhone"
            android:layout_width="match_parent" android:layout_height="50dp"
            android:layout_marginTop="6dp" android:background="@drawable/bg_input"
            android:paddingStart="14dp" android:paddingEnd="14dp"
            android:hint="Mobile number" android:inputType="phone"
            android:textSize="15sp" android:textColor="#1A0A00"
            android:textColorHint="#BBBBBB"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Default Address" android:textSize="13sp"
            android:textColor="#6B3A2A" android:textStyle="bold"
            android:layout_marginTop="18dp"/>
        <EditText android:id="@+id/etAddress"
            android:layout_width="match_parent" android:layout_height="70dp"
            android:layout_marginTop="6dp" android:background="@drawable/bg_input"
            android:padding="14dp" android:gravity="top"
            android:hint="Your delivery address"
            android:inputType="textMultiLine"
            android:textSize="15sp" android:textColor="#1A0A00"
            android:textColorHint="#BBBBBB"/>

        <Button android:id="@+id/btnSave"
            android:layout_width="match_parent" android:layout_height="50dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_button_primary"
            android:text="Save Changes"
            android:textColor="#FFFFFF" android:textSize="15sp"
            android:textStyle="bold" android:stateListAnimator="@null"/>

        <TextView android:id="@+id/tvStatus"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="" android:textSize="14sp" android:textColor="#16A34A"
            android:layout_marginTop="12dp" android:gravity="center"/>

    </LinearLayout>
</ScrollView>